rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/attachments/{attachmentId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size <= 2 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp|gif)')
        && request.resource.metadata.ownerId == userId
        && request.resource.metadata.ownerType.matches('task|goal|reflection');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
